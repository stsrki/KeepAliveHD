    <Compile Update="Forms\DriveSettingsMulti.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="Forms\Main.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="Forms\VolumeNames.cs">
      <SubType>Form</SubType>
    </Compile>
  </ItemGroup>
</Project>